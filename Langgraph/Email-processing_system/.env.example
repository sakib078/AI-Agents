# =============================================================
#  Email-processing agent — copy this to .env at the repo root.
#  .env is gitignored; this .example file is safe to commit.
# =============================================================

# --- LLM (Groq) — REQUIRED ---
GROQ_API_KEY=your_groq_api_key

# --- Optional: Langfuse tracing ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Gmail auth is NOT via env vars — it uses credentials.json -> token.json
# (OAuth flow in the notebook). See README.md for the Google Cloud setup.