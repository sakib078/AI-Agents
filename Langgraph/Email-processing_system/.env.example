# --- LLM (Groq) ---
GROQ_API_KEY=your_groq_api_key

# --- Gmail MCP server (Google Cloud project) ---
# Remote (HTTP) server:
GMAIL_MCP_URL=https://gmailmcp.googleapis.com/mcp/v1

# Local stdio server (alternative to the two vars above):
# GMAIL_MCP_COMMAND=npx
# GMAIL_MCP_ARGS=@your/gmail-mcp-server
# GOOGLE_APPLICATION_CREDENTIALS=./credentials.json

# --- Behaviour flags ---
# "draft" (default, creates a Gmail draft) or "send" (actually sends the reply)
SEND_EMAILS=draft
# set to 1 to let the spam node move spam to Trash; anything else = read-only
APPLY_GMAIL_ACTIONS=0

# --- Optional: Langfuse tracing ---
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
